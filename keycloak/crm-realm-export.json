{
  "realm": "crm-realm",
  "enabled": true,
  "displayName": "LuxStay Rewards",
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Administrateur hotel, acces total"
      },
      {
        "name": "USER",
        "description": "Client fidelite, acces lecture de son profil"
      },
      {
        "name": "STAFF",
        "description": "Personnel hotel, peut creer des reservations"
      }
    ]
  },
  "clients": [
    {
      "clientId": "crm-frontend",
      "name": "crm-frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ]
    },
    {
      "clientId": "crm-backend",
      "name": "crm-backend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "crm-backend-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true
    }
  ],
  "users": [
    {
      "username": "admin-luxstay",
      "email": "admin@luxstay.com",
      "firstName": "Admin",
      "lastName": "LuxStay",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    },
    {
      "username": "youssef.elfassi",
      "email": "youssef@test.com",
      "firstName": "Youssef",
      "lastName": "El Fassi",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "User1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    },
    {
      "username": "staff.hotel",
      "email": "staff@luxstay.com",
      "firstName": "Staff",
      "lastName": "Hotel",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Staff1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "STAFF"
      ]
    }
  ]
}
